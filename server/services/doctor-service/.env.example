# Server Configuration
PORT=5003
NODE_ENV=development

# MongoDB (Doctor Database - Isolated)
MONGO_URI=mongodb://localhost:27019/careline_doctor_db

# JWT Configuration (must match auth-service)
JWT_ACCESS_SECRET=your_access_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_ACCESS_EXPIRY=1d
JWT_REFRESH_EXPIRY=7d

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin123@localhost:5672

# Cloudinary (for doctor avatars/documents)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Cross-Service Communication
AUTH_SERVICE_URL=http://localhost:5001
PATIENT_SERVICE_URL=http://localhost:5002
APPOINTMENT_SERVICE_URL=http://localhost:5004

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug
