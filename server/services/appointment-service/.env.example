# Server Configuration
PORT=5004
NODE_ENV=development

# MongoDB (Appointment Database - Isolated)
MONGO_URI=mongodb://localhost:27020/careline_appointment_db

# JWT Configuration (must match auth-service)
JWT_ACCESS_SECRET=your_access_secret_key_here

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin123@localhost:5672

# Cross-Service Communication
AUTH_SERVICE_URL=http://localhost:5001
PATIENT_SERVICE_URL=http://localhost:5002
DOCTOR_SERVICE_URL=http://localhost:5003

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@careline360.com

# Jitsi Configuration
JITSI_DOMAIN=meet.jit.si
JITSI_PREFIX=CareLine360

# Client URL (for CORS and email links)
CLIENT_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Scheduler Configuration
REMINDER_WINDOW_MINUTES=10
ADVANCE_REMINDER_HOURS=24
